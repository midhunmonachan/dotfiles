#!/usr/bin/env bash
set -euo pipefail

BUILD_SCRIPT="$(dirname "$0")/../build/dot.sh"

# Test: Check if the script has a shebang
if head -n 1 "$BUILD_SCRIPT" | grep -q '^#!/usr/bin/env bash'; then
	echo "PASS: dot.sh has correct shebang."
else
	echo "FAIL: dot.sh missing or incorrect shebang."
	exit 1
fi
